# Lokalni razvoj (PostgreSQL na računalu)
PORT=5001
HOST=0.0.0.0
DB_USER=postgres
DB_HOST=localhost
DB_NAME=training_monitor_db
DB_PASSWORD=
DB_PORT=5432

# Produkcija (npr. Render): postavi DATABASE_URL iz panela baze
# DATABASE_URL=postgres://user:pass@host:5432/dbname
# Za lokalni Postgres preko URL-a bez SSL-a:
# DATABASE_SSL=false

JWT_SECRET=postavi_jak_tajni_kljuc

# Produkcija: URL frontenda (Vercel), odvojeni zarezom ako ih je više
# CORS_ORIGIN=https://tvoj-projekt.vercel.app
